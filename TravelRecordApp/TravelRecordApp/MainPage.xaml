<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:TravelRecordApp"
             x:Class="TravelRecordApp.MainPage">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="RedColor">#FF5A60</Color>
        </ResourceDictionary>
    </ContentPage.Resources>
    <StackLayout VerticalOptions="Center" Margin="20">
        <Entry x:Name="EntryEmail" Margin="10" Placeholder="Email" Keyboard="Email" TextColor="{StaticResource RedColor}"/>
        <Entry x:Name="EntryPassword" Margin="10" Placeholder="Password" IsPassword="True"  TextColor="{StaticResource RedColor}"/>
        <Button x:Name="BtnLogin" Margin="0,50,0,0" Text="Login" TextColor="White" Clicked="BtnLogin_Clicked" BackgroundColor="{StaticResource RedColor}}"/>
    </StackLayout>

</ContentPage>
