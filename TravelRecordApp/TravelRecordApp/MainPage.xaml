<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:TravelRecordApp"
             x:Class="TravelRecordApp.MainPage">

    <StackLayout VerticalOptions="Center" Margin="15">
        <Entry Margin="10" Placeholder="Email" Keyboard="Email"/>
        <Entry Margin="10" Placeholder="Password" IsPassword="True"/>
        <Button Text="Login" BackgroundColor="#3f84E3" TextColor="White"/>
    </StackLayout>

</ContentPage>
